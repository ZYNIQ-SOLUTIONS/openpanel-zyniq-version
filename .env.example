# ══════════════════════════════════════════════════════════════════
# Z-OpenPanel (ZYNIQ Cloud Analytics) — Environment Variables
# ══════════════════════════════════════════════════════════════════

# ─── Storage ────────────────────────────────────────────────────
REDIS_URL="redis://op-kv:6379"
DATABASE_URL="postgresql://postgres:postgres@op-db:5432/postgres?schema=public"
DATABASE_URL_DIRECT="${DATABASE_URL}"
CLICKHOUSE_URL="http://op-ch:8123/openpanel"

# ─── Application ────────────────────────────────────────────────
BATCH_SIZE="5000"
BATCH_INTERVAL="10000"
CONCURRENCY="10"
NEXT_PUBLIC_DASHBOARD_URL="https://admin.zyniq.cloud"
NEXT_PUBLIC_API_URL="https://api.zyniq.cloud"
WORKER_PORT=9999
COOKIE_SECRET="CHANGE_ME_RANDOM_SECRET"

# ─── Keycloak SSO (ZYNIQ Auth Service) ─────────────────────────
# Server-side (API)
KEYCLOAK_URL="https://auth.zyniq.cloud"
KEYCLOAK_REALM="zyniq-studio"
KEYCLOAK_CLIENT_ID="z-openpanel"
KEYCLOAK_CLIENT_SECRET="CHANGE_ME_FROM_KEYCLOAK_CONSOLE"

# Client-side (Dashboard — Vite env vars)
VITE_KEYCLOAK_URL="https://auth.zyniq.cloud"
VITE_KEYCLOAK_REALM="zyniq-studio"
VITE_KEYCLOAK_CLIENT_ID="z-openpanel"

# ─── OAuth Providers (Optional — Keycloak handles these) ───────
# If using direct OAuth alongside Keycloak:
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="${NEXT_PUBLIC_API_URL}/api/auth/github/callback"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="${NEXT_PUBLIC_API_URL}/api/auth/google/callback"

# ─── Branding ──────────────────────────────────────────────────
NEXT_PUBLIC_BRAND_NAME="ZYNIQ Cloud Analytics"
NEXT_PUBLIC_SUPPORT_EMAIL="support@zyniq.solutions"
